# Groq Speech-to-Text (Whisper) — get key at https://console.groq.com (starts with gsk_)
GROQ_API_KEY=

# OpenRouter LLM feedback — get key at https://openrouter.ai/keys (starts with sk-or-v1-)
OPENROUTER_API_KEY=

# Optional fallback if you named it OPENAI_API_KEY in OpenRouter
# OPENAI_API_KEY=

CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000

# Optional — auto-detected on Windows after winget install
# FFMPEG_PATH=C:\path\to\ffmpeg.exe
