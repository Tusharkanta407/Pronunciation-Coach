# Groq Speech-to-Text (Whisper) — https://console.groq.com (starts with gsk_)
GROQ_API_KEY=

# OpenRouter LLM feedback — https://openrouter.ai/keys (optional)
OPENROUTER_API_KEY=

# Production: your Vercel frontend URL (no trailing slash)
CORS_ORIGIN=https://your-app.vercel.app

# Extra origins (comma-separated), e.g. preview deployments
# CORS_ORIGINS=https://your-app-git-main-you.vercel.app

APP_URL=https://your-app.vercel.app

# ffmpeg is auto-installed on Railway via nixpacks.toml.
# Locally on Windows, winget install or set:
# FFMPEG_PATH=C:\path\to\ffmpeg.exe
