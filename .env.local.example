# --- Local dev (default) ---
# Leave NEXT_PUBLIC_API_URL unset — browser calls /api/* on same origin;
# Next.js proxies to the backend via rewrites in next.config.mjs.
# NEXT_PUBLIC_API_URL=

API_PROXY_TARGET=http://127.0.0.1:8000

# --- Vercel production ---
# Set in Vercel → Project → Settings → Environment Variables:
# API_PROXY_TARGET=https://YOUR-APP.up.railway.app
#
# Optional: call Railway directly from the browser (skip proxy).
# Requires CORS_ORIGIN on Railway = your Vercel URL.
# NEXT_PUBLIC_API_URL=https://YOUR-APP.up.railway.app
